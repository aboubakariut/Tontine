{
  "version": 2,
  "functions": {
    "api/api.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/api.php(.*)",
      "dest": "/api/api.php"
    },
    {
      "src": "/api.php(.*)",
      "dest": "/api/api.php"
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
