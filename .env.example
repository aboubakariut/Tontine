# ═════════════════════════════════════════════════════════════════
# TONTINES FACILE — Configuration Environnement
# ═════════════════════════════════════════════════════════════════

# ━━━ DATABASE ━━━
DB_HOST=localhost
DB_NAME=tontines_facile
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ━━━ SECURITY ━━━
JWT_SECRET=YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS_1234567890
APP_ENV=development
APP_DEBUG=true

# ━━━ EMAIL (SMTP) ━━━
# Utiliser SMTP générique ou services comme SendGrid, Mailgun, etc.
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@tontinesfacile.app
MAIL_FROM_NAME="Tontines Facile"

# ━━━ MOBILE MONEY (Orange/MTN/Wave) ━━━
# À remplir selon le prestataire choisi
MOBILE_MONEY_PROVIDER=orange
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_API_SECRET=
MOBILE_MONEY_MERCHANT_ID=

# ━━━ SMS (Twilio ou autre) ━━━
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# ━━━ APP ━━━
APP_VERSION=1.0.0
APP_URL=https://tontinesfacile.app
APP_NAME=Tontines Facile

# ━━━ LIMITS ━━━
MAX_LOGIN_ATTEMPTS=5
TOKEN_EXPIRY=604800
INVITE_EXPIRY_DAYS=7
PASSWORD_MIN_LENGTH=8

# ━━━ FEATURES ━━━
FEATURE_2FA=false
FEATURE_EMAIL_VERIFICATION=true
FEATURE_MOBILE_MONEY=false
FEATURE_PUSH_NOTIFICATIONS=true
