# ═════════════════════════════════════════════════════════════════
# TONTINES FACILE — Configuration Environnement
# ═════════════════════════════════════════════════════════════════

# ━━━ DATABASE ━━━
DB_HOST = gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT = 4000
DB_USER = 2oV9Y92JFQWWY6V.root
DB_PASS = KQ95KPuXVqOFeFIa
DB_NAME = tontines
JWT_SECRET = TontinesFacile2025ByIPT!MonSecretTresLongEtSecurise
APP_URL = https://tontine-iota.vercel.app
MAIL_FROM = tontinesfacile@gmail.com
DB_CHARSET=utf8mb4

# ━━━ SECURITY ━━━
APP_ENV=development
APP_DEBUG=true

# ━━━ EMAIL (API Brevo — https://www.brevo.com, 300 emails/jour gratuits) ━━━
# Créer un compte, puis SMTP & API > API Keys > Generate a new API key
BREVO_API_KEY=

# ━━━ EMAIL (SMTP, non utilisé actuellement — conservé pour référence) ━━━
# Utiliser SMTP générique ou services comme SendGrid, Mailgun, etc.
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@tontinesfacile.app
MAIL_FROM_NAME="Tontines Facile"

# ━━━ MOBILE MONEY (Orange/MTN/Wave) ━━━
# À remplir selon le prestataire choisi
MOBILE_MONEY_PROVIDER=orange
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_API_SECRET=
MOBILE_MONEY_MERCHANT_ID=

# ━━━ MOBILE MONEY DE L'ADMIN ━━━
# Aucune clé API nécessaire : chaque tontine utilise le numéro Mobile Money
# personnel de son admin (MTN MoMo ou Orange Money), renseigné directement
# dans les paramètres de la tontine. L'app ne détient jamais aucun fonds.

# ━━━ SMS (Twilio ou autre) ━━━
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# ━━━ APP ━━━
APP_VERSION=1.0.0
APP_URL=https://tontine-iota.vercel.app
APP_NAME=Tontines Facile

# ━━━ LIMITS ━━━
MAX_LOGIN_ATTEMPTS=5
TOKEN_EXPIRY=604800
INVITE_EXPIRY_DAYS=7
PASSWORD_MIN_LENGTH=8

# ━━━ FEATURES ━━━
FEATURE_2FA=false
FEATURE_EMAIL_VERIFICATION=true
FEATURE_MOBILE_MONEY=false
FEATURE_PUSH_NOTIFICATIONS=true
